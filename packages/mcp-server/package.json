{
  "name": "@henkas/orderfood",
  "version": "0.1.0",
  "description": "MCP server for AI-driven food delivery on Uber Eats and Thuisbezorgd",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
